# Generated by swiftdeploy — do not edit manually.
# Source of truth: manifest.yaml  |  Regenerate: swiftdeploy init

name: swiftdeploy

networks:
    {{ network_name }}:
        driver: {{ network_driver }}

volumes:
    # Named volume for app service logs (/var/log/swiftdeploy inside container)
    # Pre-owned by appuser:appgroup in Dockerfile so non-root write works on mount
    app_logs:
        driver: local
    # Named volume for nginx access + error logs (/var/log/nginx inside container)
    nginx_logs:
        driver: local

services:

    # ---------------------------------------------------------------------------
    # OPA policy sidecar
    #
    # Loads all .rego files from ./policies at startup.
    # Bound to 127.0.0.1:8181 only — reachable by the host CLI but NOT via nginx.
    # expose: alone would not make this reachable from the host; ports: with
    # 127.0.0.1 binding satisfies both requirements: host CLI can query it,
    # and it is never accessible via the nginx port or publicly.
    # ---------------------------------------------------------------------------
    opa:
        image: openpolicyagent/opa:latest-static
        container_name: {{ container_opa_name }}
        restart: {{ restart_policy }}
        command:
            - "run"
            - "--server"
            - "--addr=0.0.0.0:8181"
            - "/policies"
        # /policies is passed as the bundle directory — OPA loads all .rego files
        # and data.json from it automatically. No --config-file needed.
        volumes:
            - ./policies:/policies:ro
        networks:
            - {{ network_name }}
        ports:
            # 127.0.0.1 binding: reachable from host CLI, not exposed publicly.
            # nginx has no location block for OPA — this port is invisible to it.
            - "127.0.0.1:8181:8181"
        cap_drop:
            - ALL
        security_opt:
            - no-new-privileges:true

    # ---------------------------------------------------------------------------
    # Application service
    #
    # NO `ports:` block — the host never binds to this port.
    # `expose:` documents the port for inter-container communication only.
    # All external traffic routes exclusively through nginx.
    # ---------------------------------------------------------------------------
    app:
        image: {{ service_image }}
        container_name: {{ container_app_name }}
        restart: {{ restart_policy }}
        expose:
            - "{{ service_port }}"
        environment:
            MODE: "{{ mode }}"
            APP_VERSION: "{{ app_version }}"
            APP_PORT: "{{ service_port }}"
        networks:
            - {{ network_name }}
        volumes:
            - app_logs:/var/log/swiftdeploy
        cap_drop:
            - ALL
        security_opt:
            - no-new-privileges:true
        depends_on:
            opa:
                condition: service_started
        healthcheck:
            test: ["CMD-SHELL", "wget -qO- http://localhost:{{ service_port }}/healthz || exit 1"]
            interval: 10s
            timeout: 3s
            start_period: 10s
            retries: 3

    # ---------------------------------------------------------------------------
    # Nginx reverse proxy
    #
    # The ONLY service with a publicly host-bound port.
    # nginx.conf is mounted read-only — container cannot modify its own config.
    # ---------------------------------------------------------------------------
    nginx:
        image: {{ nginx_image }}
        container_name: {{ container_nginx_name }}
        restart: {{ restart_policy }}
        ports:
            - "{{ nginx_port }}:{{ nginx_port }}"
        networks:
            - {{ network_name }}
        volumes:
            - ./nginx.conf:/etc/nginx/nginx.conf:ro
            - nginx_logs:/var/log/nginx
        cap_drop:
            - ALL
        cap_add:
            - NET_BIND_SERVICE
            - SETUID
            - SETGID
            - CHOWN
            - DAC_OVERRIDE
        security_opt:
            - no-new-privileges:true
        depends_on:
            app:
                condition: service_healthy
        healthcheck:
            test: ["CMD-SHELL", "wget -qO- http://localhost:{{ nginx_port }}/healthz || exit 1"]
            interval: 10s
            timeout: 3s
            start_period: 15s
            retries: 3
