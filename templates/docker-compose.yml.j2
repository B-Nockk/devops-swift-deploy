# Generated by swiftdeploy — do not edit manually.
# Source of truth: manifest.yaml  |  Regenerate: swiftdeploy init

name: swiftdeploy

networks:
  {{ network_name }}:
    driver: {{ network_driver }}

volumes:
  # Named volume for app service logs (/var/log/swiftdeploy inside container)
  # Pre-owned by appuser:appgroup in Dockerfile so non-root write works on mount
  app_logs:
    driver: local
  # Named volume for nginx access + error logs (/var/log/nginx inside container)
  nginx_logs:
    driver: local

services:

  # ---------------------------------------------------------------------------
  # Application service
  #
  # NO `ports:` block — the host never binds to this port.
  # `expose:` documents the port for inter-container communication only.
  # All external traffic routes exclusively through nginx.
  # ---------------------------------------------------------------------------
  app:
    image: {{ service_image }}
    container_name: swiftdeploy-app
    restart: {{ restart_policy }}
    expose:
      - "{{ service_port }}"
    environment:
      MODE: "{{ mode }}"
      APP_VERSION: "{{ app_version }}"
      APP_PORT: "{{ service_port }}"
    networks:
      - {{ network_name }}
    volumes:
      # Named volume — nginx_logs path matches Dockerfile's mkdir + chown target
      - app_logs:/var/log/swiftdeploy
    # CIS Docker Benchmark: drop all capabilities, add none back.
    # The Go binary needs no Linux capabilities to serve HTTP on non-privileged port.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:{{ service_port }}/healthz || exit 1"]
      interval: 10s
      timeout: 3s
      start_period: 10s
      retries: 3

  # ---------------------------------------------------------------------------
  # Nginx reverse proxy
  #
  # The ONLY service with a host-bound port.
  # nginx.conf is mounted read-only — container cannot modify its own config.
  # ---------------------------------------------------------------------------
  nginx:
    image: {{ nginx_image }}
    container_name: swiftdeploy-nginx
    restart: {{ restart_policy }}
    ports:
      - "{{ nginx_port }}:{{ nginx_port }}"
    networks:
      - {{ network_name }}
    volumes:
      # nginx.conf mounted read-only — immutable at runtime
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      # Named volume for access + error logs; matches access_log path in nginx.conf
      - nginx_logs:/var/log/nginx
    # nginx master process needs SETUID/SETGID to drop to the `nginx` worker user.
    # NET_BIND_SERVICE is needed only if nginx_port < 1024.
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - SETUID
      - SETGID
      - CHOWN         # nginx needs to chown its tmp/cache dirs on startup
      - DAC_OVERRIDE  # nginx reads config files owned by root
    security_opt:
      - no-new-privileges:true
    depends_on:
      app:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:{{ nginx_port }}/healthz || exit 1"]
      interval: 10s
      timeout: 3s
      start_period: 15s
      retries: 3
