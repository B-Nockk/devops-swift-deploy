# Generated by swiftdeploy — do not edit manually.
# Source of truth: manifest.yaml  |  Regenerate: swiftdeploy init

user  nginx;
worker_processes  auto;
error_log  /var/log/nginx/error.log warn;
pid        /var/run/nginx.pid;

events {
    worker_connections  1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # -------------------------------------------------------------------------
    # Custom access log format
    # Spec: $time_iso8601 | $status | ${request_time}s | $upstream_addr | $request
    # Written to named volume: nginx_logs
    # -------------------------------------------------------------------------
    log_format swiftdeploy_fmt
        '$time_iso8601 | $status | ${request_time}s | $upstream_addr | $request';

    access_log /var/log/nginx/access.log swiftdeploy_fmt;
    error_log  /var/log/nginx/error.log warn;

    sendfile           on;
    keepalive_timeout  65;

    # -------------------------------------------------------------------------
    # Upstream — app service on the internal Docker network.
    # This port is NEVER bound to the host; only nginx reaches it.
    # -------------------------------------------------------------------------
    upstream swiftdeploy_app {
        server {{ service_host }}:{{ service_port }};
        keepalive 16;
    }

    server {
        listen {{ nginx_port }};
        server_name _;

        # -----------------------------------------------------------------------
        # Proxy timeouts — sourced from manifest nginx.proxy_timeout
        # -----------------------------------------------------------------------
        proxy_connect_timeout {{ proxy_timeout }}s;
        proxy_send_timeout    {{ proxy_timeout }}s;
        proxy_read_timeout    {{ proxy_timeout }}s;

        # -----------------------------------------------------------------------
        # Standard proxy headers
        # -----------------------------------------------------------------------
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # -----------------------------------------------------------------------
        # SwiftDeploy identity header on every response
        # -----------------------------------------------------------------------
        add_header X-Deployed-By "swiftdeploy" always;

        # -----------------------------------------------------------------------
        # X-Mode passthrough
        #
        # nginx strips upstream response headers that aren't in a safe-list by
        # default via proxy_hide_header behaviour. Two directives are needed:
        #
        #   proxy_pass_header X-Mode  — tells nginx to pass X-Mode from upstream
        #                               response through to the client
        #   add_header X-Mode         — NOT used here; the value comes from
        #                               upstream, not from nginx config
        #
        # The Go canary service sets X-Mode: canary on every response.
        # Stable mode sets no X-Mode header — absence is the signal.
        # -----------------------------------------------------------------------
        proxy_pass_header X-Mode;

        # -----------------------------------------------------------------------
        # Wire 5xx codes to JSON error handlers
        # -----------------------------------------------------------------------
        error_page 502 = @error_502;
        error_page 503 = @error_503;
        error_page 504 = @error_504;

        # -----------------------------------------------------------------------
        # Main proxy location
        # -----------------------------------------------------------------------
        location / {
            proxy_pass http://swiftdeploy_app;
        }

        # -----------------------------------------------------------------------
        # JSON error response bodies for 502 / 503 / 504
        #
        # Rules:
        #   - default_type must be set per location (not inherited by named locations)
        #   - JSON strings use ASCII only — multi-byte chars (em dashes etc.) can
        #     cause nginx to miscount content-length and truncate the body
        #   - Each location repeats X-Deployed-By — add_header is NOT inherited
        #     into named @locations from the parent server block
        #   - contact and service_name are injected from manifest at init time
        # -----------------------------------------------------------------------
        location @error_502 {
            default_type application/json;
            add_header X-Deployed-By "swiftdeploy" always;
            return 502 '{"error":"Bad Gateway - upstream service unavailable","code":"502","service":"{{ service_name }}","contact":"{{ contact }}"}';
        }

        location @error_503 {
            default_type application/json;
            add_header X-Deployed-By "swiftdeploy" always;
            return 503 '{"error":"Service Unavailable - upstream not ready","code":"503","service":"{{ service_name }}","contact":"{{ contact }}"}';
        }

        location @error_504 {
            default_type application/json;
            add_header X-Deployed-By "swiftdeploy" always;
            return 504 '{"error":"Gateway Timeout - upstream did not respond in time","code":"504","service":"{{ service_name }}","contact":"{{ contact }}"}';
        }
    }
}
