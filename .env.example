# /.env.example
# SwiftDeploy environment configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Rules:
#   - .env is gitignored — never commit it
#   - Shell environment variables take priority over values set here
#   - For required vars, the listed values are the defaults if not set
#   - Run `make inspect` to see the fully resolved configuration at any time
# ──────────────────────────────────────────────────────────────────────────────

# ── Paths ─────────────────────────────────────────────────────────────────────
# Where swiftdeploy looks for the manifest and templates, and where it writes
# generated files. Change SWIFTDEPLOY_MANIFEST if your file is named manifest.yml

SWIFTDEPLOY_MANIFEST=manifest.yaml
SWIFTDEPLOY_TEMPLATES=templates
SWIFTDEPLOY_OUTPUT=.

# ── Service ───────────────────────────────────────────────────────────────────
# The Go HTTP service container configuration.
# SERVICE_IMAGE must exist locally before running make deploy (build with make build)

SERVICE_IMAGE=swift-deploy-1-node:latest
SERVICE_PORT=3000
SERVICE_VERSION=0.0.1
RESTART_POLICY=unless-stopped

# ── Nginx ─────────────────────────────────────────────────────────────────────
# NGINX_PORT is the only port exposed to the host.
# NGINX_CONTACT appears in JSON error bodies (502/503/504).

NGINX_IMAGE=nginx:latest
NGINX_PORT=8080
NGINX_PROXY_TIMEOUT=30
NGINX_CONTACT=ops@swiftdeploy.internal

# ── Network ───────────────────────────────────────────────────────────────────
# Internal Docker bridge network. Containers communicate over this.
# The service port is never exposed to the host — only nginx is.

NETWORK_NAME=swiftdeploy-net
NETWORK_DRIVER=bridge

# ── Named containers ───────────────────────────────────────────────────────────────────
# named containers
CONTAINER_OPA_NAME=nockk-opa-v1
CONTAINER_NGINX_NAME=nockk-nginx-v1
CONTAINER_APP_NAME=nockk-swiftdeploy-v1

# ports - addr
OPA_HOST=http://localhost:8181

# ── Runtime ───────────────────────────────────────────────────────────────────
# Deployment mode. swiftdeploy promote [canary|stable] updates this in
# manifest.yaml directly — you do not need to update MODE here manually.

MODE=stable
